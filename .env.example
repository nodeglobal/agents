# DeltaNode Agents — Environment Variables
# Copy this to .env and fill in your values

# Required — Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Discord notifications (leave empty to use web dashboard only)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Optional — Workspace path (default: ~/deltanode-workspace)
WORKSPACE_PATH=~/deltanode-workspace

# Optional — Server port (default: 8000)
PORT=8000
